# Pi: keep personal/runtime state and secrets out of dotfiles
.pi/agent/cache/**
.pi/agent/sessions/**
.pi/agent/git/**
.pi/agent/npm/
.pi/agent/run-history.jsonl
.pi/agent/trust.json
.pi/agent/auth.json
.pi/agent/mcp.json
.pi/agent/mcp-cache.json
.pi/agent/mcp-cache/**
.pi/context-mode/**

# Allow portable Pi preferences only
!.pi/agent/keybindings.json
!.pi/agent/settings.json
!.pi/agent/themes/
!.pi/agent/themes/*.json

# Local package installs/caches under synced config dirs
.config/**/node_modules/**
.config/**/.cache/**
.config/**/cache/**
